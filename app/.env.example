# Copy this file to ".env" and fill in the values from your Supabase project
# (Supabase dashboard -> Project Settings -> API).
#
# These are PUBLIC values, safe to ship to the browser. Real protection comes
# from the Row-Level Security policies in supabase/schema.sql.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
